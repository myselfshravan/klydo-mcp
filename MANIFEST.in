# Include important documentation and configuration files in the distribution
include README.md
include LICENSE
include PUBLISHING.md
include .env.example
include pyproject.toml

# Exclude development and build artifacts
exclude .gitignore
exclude .pypirc.example
exclude .env

# Exclude version control and CI/CD
global-exclude .git*
global-exclude .github

# Exclude Python cache
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .pytest_cache

# Exclude IDE files
global-exclude .vscode
global-exclude .idea
global-exclude *.swp
